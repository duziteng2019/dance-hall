/* 多巴胺风格收藏页面 - 色彩丰富、圆润可爱 */

page {
  background: linear-gradient(135deg, #FAFAFA 0%, #F8FAFC 100%);
  min-height: 100vh;
}

.collection-container {
  padding: var(--space-4);
}

/* 页面头部 */
.collection-header {
  background: var(--gradient-warning);
  border-radius: var(--radius-3xl);
  padding: var(--space-8) var(--space-6);
  margin-bottom: var(--space-6);
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-xl);
}

.collection-header::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255,255,255,0.2) 1px, transparent 1px);
  background-size: 25rpx 25rpx;
  animation: rotate 10s linear infinite;
}

@keyframes rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-4);
  backdrop-filter: blur(10rpx);
  border: 3rpx solid rgba(255,255,255,0.3);
}

.header-icon-text {
  font-size: 36rpx;
  color: white;
}

.header-title {
  font-size: var(--font-size-2xl);
  font-weight: 800;
  color: white;
  margin-bottom: var(--space-2);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.header-subtitle {
  font-size: var(--font-size-base);
  color: rgba(255,255,255,0.9);
  font-weight: 500;
}

/* 搜索栏 */
.search-section {
  margin-bottom: var(--space-6);
}

.search-container {
  background: white;
  border-radius: var(--radius-2xl);
  padding: var(--space-4) var(--space-5);
  display: flex;
  align-items: center;
  gap: var(--space-3);
  border: none;
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(10rpx);
}

.search-icon {
  color: var(--dopamine-yellow);
  font-size: var(--font-size-lg);
}

.search-input {
  flex: 1;
  font-size: var(--font-size-base);
  color: var(--text-primary);
  background: transparent;
  border: none;
  outline: none;
  font-weight: 500;
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

/* 收藏列表 */
.collection-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
}

.collection-item {
  background: white;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  position: relative;
  border: none;
  transition: all var(--transition-normal);
  box-shadow: var(--shadow-sm);
  transform: translateY(0);
}

.collection-item:hover {
  transform: translateY(-6rpx);
  box-shadow: var(--shadow-xl);
}

.collection-item:active {
  transform: scale(0.98);
}

/* 收藏项目图片 */
.item-image-section {
  position: relative;
  height: 180rpx;
  overflow: hidden;
}

.item-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: var(--radius-2xl) var(--radius-2xl) 0 0;
  transition: transform var(--transition-slow);
}

.collection-item:hover .item-image {
  transform: scale(1.05);
}

.item-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.3));
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: var(--space-4);
}

.rating-badge {
  background: rgba(255,255,255,0.95);
  color: var(--dopamine-yellow);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  font-size: var(--font-size-xs);
  font-weight: 800;
  backdrop-filter: blur(10rpx);
  box-shadow: var(--shadow-sm);
}

.delete-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: var(--radius-full);
  background: rgba(255,255,255,0.9);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-fast);
  backdrop-filter: blur(10rpx);
  box-shadow: var(--shadow-sm);
}

.delete-btn:active {
  transform: scale(0.9);
  background: var(--gradient-warning);
}

/* 收藏项目内容 */
.item-content {
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.item-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-2);
}

.item-name {
  font-size: var(--font-size-lg);
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.3;
  flex: 1;
  letter-spacing: -0.3rpx;
}

.collect-time {
  font-size: var(--font-size-xs);
  color: var(--dopamine-purple);
  font-weight: 600;
  white-space: nowrap;
}

.item-address {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.address-icon {
  color: var(--dopamine-cyan);
  font-size: var(--font-size-sm);
}

.address-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  flex: 1;
  font-weight: 500;
}

.item-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: var(--font-size-base);
  font-weight: 700;
  color: var(--dopamine-orange);
}

.detail-btn {
  background: var(--gradient-primary);
  color: white;
  border: none;
  border-radius: var(--radius-full);
  padding: var(--space-2) var(--space-4);
  font-size: var(--font-size-xs);
  font-weight: 600;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-sm);
}

.detail-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: var(--space-20) var(--space-4);
}

.empty-icon-wrapper {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-full);
  background: var(--gradient-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto var(--space-6);
  animation: bounce 2s infinite;
}

.empty-icon {
  font-size: 56rpx;
  color: white;
}

.empty-title {
  font-size: var(--font-size-2xl);
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: var(--space-3);
  letter-spacing: -0.5rpx;
}

.empty-subtitle {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  margin-bottom: var(--space-8);
  line-height: 1.6;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: var(--space-4);
  left: 50%;
  transform: translateX(-50%);
  background: white;
  border-radius: var(--radius-2xl);
  padding: var(--space-3) var(--space-4);
  box-shadow: var(--shadow-xl);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.2);
}

.clear-all-btn {
  background: var(--gradient-warning);
  color: white;
  border: none;
  border-radius: var(--radius-full);
  padding: var(--space-3) var(--space-6);
  font-size: var(--font-size-base);
  font-weight: 700;
  transition: all var(--transition-fast);
  box-shadow: var(--shadow-md);
}

.clear-all-btn:active {
  transform: scale(0.95);
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: var(--space-12) var(--space-4);
}

.loading-icon {
  width: 60rpx;
  height: 60rpx;
  border: 3rpx solid var(--dopamine-purple);
  border-top: 3rpx solid transparent;
  border-radius: var(--radius-full);
  animation: spin 1s linear infinite;
  margin: 0 auto var(--space-4);
}

.loading-text {
  font-size: var(--font-size-base);
  color: var(--text-secondary);
  font-weight: 600;
}

/* 响应式设计 */
@media (max-width: 480px) {
  .collection-container {
    padding: var(--space-3);
  }
  
  .collection-header {
    padding: var(--space-6) var(--space-4);
    margin-bottom: var(--space-4);
  }
  
  .header-icon {
    width: 64rpx;
    height: 64rpx;
  }
  
  .header-title {
    font-size: var(--font-size-xl);
  }
  
  .search-container {
    padding: var(--space-3) var(--space-4);
  }
}

/* 动画效果 */
@keyframes bounce {
  0%, 20%, 53%, 80%, 100% {
    transform: translate3d(0,0,0);
  }
  40%, 43% {
    transform: translate3d(0,-12rpx,0);
  }
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(40rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.animate-slideInRight {
  animation: slideInRight 0.6s ease-out;
}

/* 彩色圆点装饰 */
.color-dots {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: var(--radius-full);
  animation: floatDot 4s ease-in-out infinite;
}

.color-dots:nth-child(1) {
  top: 15%;
  left: 20%;
  background: var(--dopamine-pink);
  animation-delay: 0s;
}

.color-dots:nth-child(2) {
  top: 70%;
  right: 25%;
  background: var(--dopamine-cyan);
  animation-delay: 1.5s;
}

.color-dots:nth-child(3) {
  bottom: 25%;
  left: 15%;
  background: var(--dopamine-yellow);
  animation-delay: 3s;
}

@keyframes floatDot {
  0%, 100% {
    transform: translateY(0) scale(1);
  }
  50% {
    transform: translateY(-15rpx) scale(1.3);
  }
}